#####################################
# Rofi                              #
#####################################

set $mode_rofi Rofi: [r]un [a]pps [w]indows [s]sh [p]owermenu p[o]werprofiles
bindsym $mod+d mode "$mode_rofi"
mode "$mode_rofi" {
    bindsym r exec rofi -show run; mode "default"
    bindsym a exec rofi -show drun; mode "default"
    bindsym w exec rofi -show window; mode "default"
    bindsym s exec rofi -show ssh; mode "default"
    bindsym p exec rofi -show powermenu; mode "default"
    bindsym o exec rofi -show powerprofiles; mode "default"

    bindsym Escape mode "default"
    bindsym Return mode "default"
}

